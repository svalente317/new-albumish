package id3;

class Id3Tag {
    V1_Tag v1tag;
    V2_Tag v2tag;

    Id3Info get_id3_info() {
        var info = null;
        if this.v2tag != null {
            return this.v2tag.get_id3_info();
        }
        if this.v1tag != null {
            return this.v1tag.get_id3_info();
        }
        return null;
    }

    byte[] get_apic_data() {
        if this.v2tag != null {
            return this.v2tag.get_apic_data();
        }
        return null;
    }
}
